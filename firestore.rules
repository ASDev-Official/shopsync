rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Users ────────────────────────────────────────────────────────────────
    // Any authenticated user may read any user profile.
    // This is required for:
    //   • Displaying collaborator names / avatars inside shared lists
    //   • Querying the users collection by email when sharing a list
    //   • GravatarService, AIPreferenceService, and UserAvatar reads
    // Only the owning user may write their own profile document.
    match /users/{userId} {
      allow read:   if request.auth != null;
      allow write:  if request.auth != null && request.auth.uid == userId;
    }

    // ─── Lists ────────────────────────────────────────────────────────────────
    // Membership is stored in the `members` array on the list document itself.
    match /lists/{listId} {
      // Any authenticated user may create a list as long as they include
      // themselves in the members array.
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.members;

      // Only existing members may read or update a list.
      allow read, update: if request.auth != null
                          && request.auth.uid in resource.data.members;

      // Only the list owner (createdBy) may delete it.
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.createdBy;

      // Helper function so subcollection rules can check membership without
      // an extra cross-document get() call on every write.
      function isMember() {
        return request.auth != null
            && request.auth.uid in
               get(/databases/$(database)/documents/lists/$(listId)).data.members;
      }

      // Items
      match /items/{itemId} {
        allow read, write: if isMember();
      }

      // Categories
      match /categories/{categoryId} {
        allow read, write: if isMember();
      }

      // Recycle bin
      match /recycled_items/{itemId} {
        allow read, write: if isMember();
      }

      // Saved locations (place selector)
      match /saved_locations/{locationId} {
        allow read, write: if isMember();
      }

      // Item templates (saved items)
      match /item_templates/{templateId} {
        allow read, write: if isMember();
      }
    }

    // ─── List Groups ──────────────────────────────────────────────────────────
    // Membership is stored in the `members` array on the group document.
    match /list_groups/{groupId} {
      // Any authenticated user may create a group as long as they include
      // themselves in the members array.
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.members;

      // Only existing members may read, update, or delete a group.
      allow read, update, delete: if request.auth != null
                                  && request.auth.uid in resource.data.members;
    }

    // ─── Maintenance ──────────────────────────────────────────────────────────
    // The maintenance status document is read during app startup
    // (MaintenanceService.checkMaintenance) before any user action is taken.
    // It should be readable by any authenticated user but is only writable via
    // the Firebase console or Admin SDK.
    match /maintenance/{docId} {
      allow read:  if request.auth != null;
      allow write: if false;
    }
  }
}